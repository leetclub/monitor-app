# Example secrets file - DO NOT commit actual secrets
# Create actual secrets using:
# kubectl create secret generic people-analytics-secrets \
#   --from-literal=db-host=your-db-host \
#   --from-literal=db-port=5432 \
#   --from-literal=db-name=people_analytics \
#   --from-literal=db-user=postgres \
#   --from-literal=db-password=your-db-password \
#   --from-literal=videoloft-email=your-email@example.com \
#   --from-literal=videoloft-password=your-password \
#   --from-literal=dashboard-access-api-key=YOUR_RANDOM_SECRET
#   --from-literal=flask-secret-key=$(openssl rand -hex 32)
#   --from-literal=google-client-id=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
#   --from-literal=vendon-api-key=YOUR_VENDON_TOKEN   # same as GAS Script Property API_KEY (monitoring-app-v2 Delay Risk)
#   --from-literal=slack-webhook-url=https://hooks.slack.com/...   # optional; strikes channel (same as GAS SLACK_WEBHOOK_URL)
#   --from-literal=slack-webhook-proxy-prefix=https://surveyapi.theleetclub.com/?url=   # optional; if cluster cannot POST to Slack directly
#   --from-literal=dashboard-super-admin-emails=admin@example.com,other@example.com   # optional; full tab access (comma-separated)
#   --from-literal=red-alert-from-email=alerts@theleetclub.com
#   --from-literal=red-alert-smtp-host=smtp.gmail.com
#   --from-literal=red-alert-smtp-port=587
#   --from-literal=red-alert-smtp-user=alerts@theleetclub.com
#   --from-literal=red-alert-smtp-pass=YOUR_APP_PASSWORD
#
# dashboard-access-api-key must match Apps Script property DASHBOARD_ACCESS_API_KEY (header X-Dashboard-Access-Secret).
# flask-secret-key: Flask signed cookies for /api/auth/google and /api/me (monitoring-app-v2). Required in production (api refuses dev-change-me).
# Optional deployment env (not secret): SESSION_LIFETIME_HOURS (default 12), MAX_CONTENT_LENGTH_BYTES (default 2MiB JSON bodies).
# google-client-id: Same Web client ID as in monitoring-app-v2 ConfigMap GOOGLE_CLIENT_ID (Google Cloud Console).

apiVersion: v1
kind: Secret
metadata:
  name: people-analytics-secrets
  namespace: default
type: Opaque
stringData:
  db-host: "your-digitalocean-db-host.db.ondigitalocean.com"
  db-port: "5432"
  db-name: "people_analytics"
  db-user: "postgres"
  db-password: "CHANGE_ME"
  videoloft-email: "CHANGE_ME"
  # Note: Videoloft API uses 'email' field, but you can use your username if your account uses username
  # Alternative: use videoloft-username instead of videoloft-email
  videoloft-password: "CHANGE_ME"
  dashboard-access-api-key: "CHANGE_ME_GENERATE_RANDOM_MATCH_APPS_SCRIPT"
  # Red Alert operator email alerts (optional; enable via RED_ALERT_EMAIL_ENABLED in Deployment)
  red-alert-from-email: "alerts@theleetclub.com"
  red-alert-smtp-host: "smtp.gmail.com"
  red-alert-smtp-port: "587"
  red-alert-smtp-user: "alerts@theleetclub.com"
  red-alert-smtp-pass: "CHANGE_ME"

