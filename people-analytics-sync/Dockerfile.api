FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY . .
# Must match Kubernetes containerPort + probes (people-analytics-api uses 5000).
ENV PORT=5000
EXPOSE 5000
CMD exec gunicorn --bind 0.0.0.0:${PORT} --workers 2 --threads 4 --timeout 120 "api_service:app"
